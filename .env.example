MEDIA_CRAWLER_DIR=vendor/MediaCrawler
CRAWLER_OUTPUT_DIR=data/raw
PROCESSED_OUTPUT_DIR=data/processed
CHROMA_PERSIST_DIR=data/chroma
MEDIACRAWLER_PYTHON_EXE=.conda/mediacrawler/python.exe
PLAYWRIGHT_BROWSERS_PATH=.ms-playwright
LOG_LEVEL=INFO
LLM_PROVIDER=disabled
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:3b-instruct
LLM_API_KEY=local-dev
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1200

# --- Agent 4 (RAG Memory) ---
AGENT4_PERSIST_DIR=data/chroma
AGENT4_SEED_DIR=assets/seeds
AGENT4_EMBEDDING_PROVIDER=local-bge
AGENT4_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
AGENT4_EMBEDDING_BASE_URL=
AGENT4_EMBEDDING_API_KEY=
AGENT4_TOP_K_RECALL=20
AGENT4_TOP_K_FINAL=5
AGENT4_MMR_LAMBDA=0.7
AGENT4_MAX_PER_STYLE=2
AGENT4_MIN_QUALITY_SCORE=0.0
